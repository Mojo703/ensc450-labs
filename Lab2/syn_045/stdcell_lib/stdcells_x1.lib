library(stdcells_x1) {



  delay_model : table_lookup ;

  time_unit : "1ns" ;

  voltage_unit : "1V" ;

  current_unit : "1mA" ;

  leakage_power_unit : "1uW" ;

  capacitive_load_unit (1,pf);



  nom_process : 1 ;

  nom_voltage : 1.0 ;

  nom_temperature : 125 ;



  operating_conditions(TT) {

    process : 1 ;

    voltage : 1.0 ;

    temperature : 125 ;

  }

  default_operating_conditions : TT ;



  input_threshold_pct_rise  : 50 ;

  input_threshold_pct_fall  : 50 ;

  output_threshold_pct_rise : 50 ;

  output_threshold_pct_fall : 50 ;



  slew_lower_threshold_pct_rise  : 30 ;

  slew_upper_threshold_pct_rise  : 70 ;

  slew_lower_threshold_pct_fall  : 30 ;

  slew_upper_threshold_pct_fall  : 70 ;



  /* ================= INV_X1 ================= */



  cell(INV_X1) {

    area : 1.0 ;

    cell_leakage_power : 0.038 ;



    pin(A) { direction : input ; capacitance : 0.002 ; }



    pin(Z) {

      direction : output ;

      function : "!A" ;



      timing() {

        related_pin : "A" ;

        timing_sense : negative_unate ;



        cell_rise (scalar) { values ("0.43"); }

        cell_fall (scalar) { values ("0.55"); }

        rise_transition (scalar) { values ("0.20"); }

        fall_transition (scalar) { values ("0.22"); }

      }

    }

  }



  /* ================= NAND_X1 ================= */



  cell(NAND_X1) {

    area : 2.0 ;

    cell_leakage_power : 0.040 ;



    pin(A) { direction : input ; capacitance : 0.002 ; }

    pin(B) { direction : input ; capacitance : 0.002 ; }



    pin(Z) {

      direction : output ;

      function : "!(A & B)" ;



      timing() {

        related_pin : "A" ;

        timing_sense : negative_unate ;



        cell_rise (scalar) { values ("0.50"); }

        cell_fall (scalar) { values ("0.80"); }

        rise_transition (scalar) { values ("0.25"); }

        fall_transition (scalar) { values ("0.30"); }

      }



      timing() {

        related_pin : "B" ;

        timing_sense : negative_unate ;



        cell_rise (scalar) { values ("0.50"); }

        cell_fall (scalar) { values ("0.80"); }

        rise_transition (scalar) { values ("0.25"); }

        fall_transition (scalar) { values ("0.30"); }

      }

    }

  }



  /* ================= NOR_X1 ================= */



  cell(NOR_X1) {

    area : 2.0 ;

    cell_leakage_power : 0.040 ;



    pin(A) { direction : input ; capacitance : 0.002 ; }

    pin(B) { direction : input ; capacitance : 0.002 ; }



    pin(Z) {

      direction : output ;

      function : "!(A | B)" ;



      timing() {

        related_pin : "A" ;

        timing_sense : negative_unate ;



        cell_rise (scalar) { values ("1.00"); }

        cell_fall (scalar) { values ("0.45"); }

        rise_transition (scalar) { values ("0.35"); }

        fall_transition (scalar) { values ("0.20"); }

      }



      timing() {

        related_pin : "B" ;

        timing_sense : negative_unate ;



        cell_rise (scalar) { values ("1.00"); }

        cell_fall (scalar) { values ("0.45"); }

        rise_transition (scalar) { values ("0.35"); }

        fall_transition (scalar) { values ("0.20"); }

      }

    }

  }



  /* ================= XOR_X1 ================= */



  cell(XOR_X1) {

    area : 3.0 ;

    cell_leakage_power : 0.038 ;



    pin(A) { direction : input ; capacitance : 0.003 ; }

    pin(B) { direction : input ; capacitance : 0.003 ; }



    pin(Z) {

      direction : output ;

      function : "A ^ B" ;



      timing() {

        related_pin : "A" ;

        timing_sense : non_unate ;



        cell_rise (scalar) { values ("0.55"); }

        cell_fall (scalar) { values ("0.55"); }

        rise_transition (scalar) { values ("0.30"); }

        fall_transition (scalar) { values ("0.30"); }

      }



      timing() {

        related_pin : "B" ;

        timing_sense : non_unate ;



        cell_rise (scalar) { values ("0.55"); }

        cell_fall (scalar) { values ("0.55"); }

        rise_transition (scalar) { values ("0.30"); }

        fall_transition (scalar) { values ("0.30"); }

      }

    }

  }

}
